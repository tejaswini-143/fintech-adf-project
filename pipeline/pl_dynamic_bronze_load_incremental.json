{
	"name": "pl_dynamic_bronze_load_incremental",
	"properties": {
		"activities": [
			{
				"name": "lkp_metadata",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_metadata_source",
						"type": "DatasetReference"
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "ForEach1",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "lkp_metadata",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('lkp_metadata').output.value",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "copy_dynamic_table",
							"type": "Copy",
							"dependsOn": [
								{
									"activity": "condition_check",
									"dependencyConditions": [
										"Completed"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlServerSource",
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"sink": {
									"type": "ParquetSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "ParquetWriteSettings"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_sql_source",
									"type": "DatasetReference",
									"parameters": {
										"table_name": {
											"value": "@item().source_table",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_application_bronze_sink",
									"type": "DatasetReference",
									"parameters": {
										"folder_name": {
											"value": "@item().target_folder",
											"type": "Expression"
										}
									}
								}
							]
						},
						{
							"name": "condition_check",
							"type": "IfCondition",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"expression": {
									"value": "@equals(item().load_type,'Incremental')",
									"type": "Expression"
								}
							}
						},
						{
							"name": "lkp_current_watermark",
							"type": "Lookup",
							"dependsOn": [
								{
									"activity": "condition_check",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlServerSource",
									"sqlReaderQuery": {
										"value": "@concat(\n'SELECT watermark_value FROM dbo.adf_metadata WHERE source_table=''', \nitem().source_table,\n''''\n)",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"dataset": {
									"referenceName": "ds_sql_source",
									"type": "DatasetReference",
									"parameters": {
										"table_name": "@item().source_table"
									}
								},
								"firstRowOnly": true
							}
						},
						{
							"name": "cpy_incremental",
							"type": "Copy",
							"dependsOn": [
								{
									"activity": "lkp_current_watermark",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlServerSource",
									"sqlReaderQuery": {
										"value": "@concat(\n    'SELECT * FROM ',\n    item().source_table,\n    ' WHERE ',\n    coalesce(item().watermark_column, 'modified_date'),\n    ' > ''',\n    activity('lkp_current_watermark').output.firstRow.watermark_value,\n    ''''\n)",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"sink": {
									"type": "ParquetSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "ParquetWriteSettings"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_sql_source",
									"type": "DatasetReference",
									"parameters": {
										"table_name": "@item().source_table"
									}
								}
							],
							"outputs": [
								{
									"referenceName": "ds_sql_sink_bronze_source",
									"type": "DatasetReference",
									"parameters": {
										"folder_name": "@item().target_folder"
									}
								}
							]
						},
						{
							"name": "lkp_new_watermark",
							"type": "Lookup",
							"dependsOn": [
								{
									"activity": "cpy_incremental",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlServerSource",
									"sqlReaderQuery": {
										"value": "@concat(\n'SELECT MAX(modified_date) AS max_watermark FROM ',\nitem().source_table\n)",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"dataset": {
									"referenceName": "ds_sql_source",
									"type": "DatasetReference",
									"parameters": {
										"table_name": "@item().source_table"
									}
								}
							}
						},
						{
							"name": "sp_update_watermark",
							"type": "SqlServerStoredProcedure",
							"dependsOn": [
								{
									"activity": "lkp_new_watermark",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [
								{
									"name": "SourceTable",
									"value": "@item().source_table"
								},
								{
									"name": "Watermark",
									"value": "@activity('lkp_new_watermark').output.firstRow.max_watermark"
								}
							],
							"typeProperties": {
								"storedProcedureName": "[dbo].[usp_UpdateWatermark]"
							},
							"linkedServiceName": {
								"referenceName": "ls_sqlserver_fintech",
								"type": "LinkedServiceReference"
							}
						}
					]
				}
			}
		],
		"annotations": []
	}
}