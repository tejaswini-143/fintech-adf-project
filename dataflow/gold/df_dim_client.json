{
	"name": "df_dim_client",
	"properties": {
		"folder": {
			"name": "Gold - Star Schema"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_client_sink",
						"type": "DatasetReference"
					},
					"name": "srcclient"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_dim_client",
						"type": "DatasetReference"
					},
					"name": "snkdimclient"
				}
			],
			"transformations": [
				{
					"name": "seldimclient"
				},
				{
					"name": "drvclientkey"
				}
			],
			"scriptLines": [
				"source(output(",
				"          loan_application_id as integer,",
				"          client_type as string,",
				"          relation_type as string,",
				"          title as string,",
				"          first_name as string,",
				"          middle_name as string,",
				"          last_name as string,",
				"          date_of_birth as date,",
				"          age as integer,",
				"          father_name as string,",
				"          spouse_name as string,",
				"          caste as string,",
				"          religion as string,",
				"          mother_tongue as string,",
				"          education_qualification as string,",
				"          gender as string,",
				"          marital_status as string,",
				"          mobile_number as string,",
				"          email as string,",
				"          is_kyc_manual as string,",
				"          kyc_type_id_1 as string,",
				"          kyc_id_value_1 as string,",
				"          kyc_type_1_expiry_date as date,",
				"          kyc_type_id_2 as string,",
				"          kyc_id_value_2 as string,",
				"          kyc_type_2_expiry_date as date,",
				"          kyc_type_id_3 as string,",
				"          kyc_id_value_3 as string,",
				"          kyc_type_3_expiry_date as date,",
				"          kyc_type_id_4 as string,",
				"          kyc_id_value_4 as string,",
				"          kyc_type_4_expiry_date as date,",
				"          is_msme as string,",
				"          is_mobile_number_verified as string,",
				"          mobile_no_verified_time as string,",
				"          is_email_verified as string,",
				"          email_verified_time as string,",
				"          is_aadhar_number_verified as string,",
				"          aadhar_no_verified_time as string,",
				"          is_pan_verified as string,",
				"          pan_no_verified_time as string,",
				"          udyam_registration_number as string,",
				"          is_udyam_registration_number_verified as string,",
				"          udyam_no_verified_time as string,",
				"          dedupe_check as string,",
				"          is_dedupe_passed as string,",
				"          dedupe_check_date as string,",
				"          dms_id as integer,",
				"          image_name as string,",
				"          geo_code as string,",
				"          is_active as string,",
				"          lms_client_id as string,",
				"          lms_customer_type_id as string,",
				"          client_creation_date as string,",
				"          created_by as string,",
				"          created_date as string,",
				"          modified_by as string,",
				"          modified_date as string,",
				"          supervised_by as string,",
				"          supervised_date as string,",
				"          is_kyc_manual_approved as string,",
				"          no_of_spdcs as integer,",
				"          is_aadhar_verification_mandatory as string,",
				"          customer_type as string,",
				"          no_of_pdcs as integer,",
				"          full_name as string,",
				"          id as integer,",
				"          member_id as long,",
				"          IsVoterVerified as boolean,",
				"          VoterVerifiedDate as date,",
				"          alternate_mobile_number as string,",
				"          mothers_maiden_name as string,",
				"          name_as_per_aadhar as string,",
				"          dob_as_per_aadhar as date,",
				"          relative_name as string,",
				"          relative_relationship as string,",
				"          is_relation_employee_of_institution as boolean,",
				"          branch_id as integer,",
				"          no_of_dependents as integer,",
				"          is_saved as boolean,",
				"          rel_emp_code as string,",
				"          same_as_mobile_no as string,",
				"          drop_reason as string,",
				"          drop_remarks as string,",
				"          is_imported_client as boolean,",
				"          is_name_matched as boolean,",
				"          name_matched_time as timestamp,",
				"          TotalCBEMI as decimal(19,2),",
				"          IsTotalCBEMIUpdated as boolean,",
				"          new_lms_client_id as string,",
				"          is_new_client_creation as boolean,",
				"          ID1VerifiedDate as timestamp,",
				"          ID2VerifiedDate as timestamp,",
				"          ID3VerifiedDate as timestamp,",
				"          ID4VerifiedDate as timestamp,",
				"          justification_reason as string,",
				"          lms_classification_customer_type as string,",
				"          NameAsPerID1 as string,",
				"          NameAsPerID2 as string,",
				"          NameAsPerID3 as string,",
				"          NameAsPerID4 as string,",
				"          KYCRetryCount as integer,",
				"          IsExiFamRel as string,",
				"          NameAsPerPAN as string,",
				"          FatherNameAsPerPAN as string,",
				"          DOBAsPerPAN as date,",
				"          CKYCNumber as string,",
				"          CBConsent as boolean,",
				"          GenericConsent as boolean,",
				"          PrivacyConsent as boolean,",
				"          IsPEP as boolean,",
				"          IsDisabled as boolean,",
				"          DisabilityType as string,",
				"          IsTaxResidentOutsideIndia as boolean,",
				"          SpouseFirstName as string,",
				"          SpouseLastName as string,",
				"          SpouseMiddleName as string,",
				"          CBEnquiryRefNo as long,",
				"          ID1Verified as boolean,",
				"          ID2Verified as boolean,",
				"          ID3Verified as boolean,",
				"          ID4Verified as boolean,",
				"          IsEsigned as boolean,",
				"          EsignedTime as timestamp,",
				"          ocr_dms_id1 as integer,",
				"          is_ocr_verified_id1 as boolean,",
				"          ocr_dms_id2 as integer,",
				"          is_ocr_verified_id2 as boolean,",
				"          ocr_dms_id3 as integer,",
				"          is_ocr_verified_id3 as boolean,",
				"          ocr_dms_id4 as integer,",
				"          is_ocr_verified_id4 as boolean,",
				"          isQrDone as boolean,",
				"          TotalCBEMI_clean as decimal(19,2),",
				"          customer_type_clean as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> srcclient",
				"srcclient select(mapColumn(",
				"          loan_application_id,",
				"          client_id = id,",
				"          full_name,",
				"          gender,",
				"          date_of_birth,",
				"          age,",
				"          marital_status,",
				"          customer_type,",
				"          client_type,",
				"          mobile_number,",
				"          email,",
				"          education_qualification,",
				"          religion,",
				"          caste,",
				"          each(match(/* All input columns */true()),",
				"               /* Input name */$$ = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> seldimclient",
				"seldimclient derive(client_key = toString(client_id)) ~> drvclientkey",
				"drvclientkey sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> snkdimclient"
			]
		}
	}
}
