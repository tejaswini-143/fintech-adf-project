{
	"name": "df_fact_loan_application",
	"properties": {
		"folder": {
			"name": "Gold - Star Schema"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_silver_application_sink",
						"type": "DatasetReference"
					},
					"name": "srcapplication"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_fact_loan_application",
						"type": "DatasetReference"
					},
					"name": "snkfact"
				}
			],
			"transformations": [
				{
					"name": "selfact"
				},
				{
					"name": "drvfact"
				}
			],
			"scriptLines": [
				"source(output(",
				"          loan_application_number as string,",
				"          temp_number as string,",
				"          branch_id as integer,",
				"          lead_id as integer,",
				"          customer_category as string,",
				"          customer_subcategory as string,",
				"          customer_type as string,",
				"          loan_type as string,",
				"          loan_purpose as string,",
				"          product as string,",
				"          loan_amount as decimal(19,2),",
				"          workflow_id as integer,",
				"          source_id as string,",
				"          consent as string,",
				"          is_active as string,",
				"          status as string,",
				"          application_applied_by as string,",
				"          application_creation_date as string,",
				"          lms_application_number as string,",
				"          is_manual_kyc as string,",
				"          manual_kyc_status as string,",
				"          manual_kyc_approved_by as string,",
				"          manual_kyc_approved_date as string,",
				"          created_by as string,",
				"          created_date as string,",
				"          modified_by as string,",
				"          modified_date as string,",
				"          supervised_by as string,",
				"          supervised_date as string,",
				"          no_of_pdcs as integer,",
				"          ln_init_fnl_consent as string,",
				"          loan_purpose_category as string,",
				"          id as integer,",
				"          wf_code as string,",
				"          is_intrnlcrdtscr_calc as boolean,",
				"          is_riskbasedpricing_calc as boolean,",
				"          is_cashflowsummary_calc as boolean,",
				"          RejectedOn as timestamp,",
				"          RejectedBy as string,",
				"          RejectedReason as string,",
				"          RejectedRemarks as string,",
				"          industry_line as string,",
				"          isNewDocSetup as boolean,",
				"          SourceOfLead as string,",
				"          ProcessBy as string,",
				"          IsDisbursed as boolean,",
				"          DisbursedTime as timestamp,",
				"          IsDataCorrectedApplication as boolean,",
				"          DCRequestedBy as string,",
				"          DCRequestedTime as timestamp,",
				"          DCRequestedReason as string,",
				"          DCRequestedRemarks as string,",
				"          IsDataCorrectionCompleted as boolean,",
				"          DCPerformedBy as string,",
				"          DCPerformedOn as timestamp,",
				"          DCCount as integer,",
				"          DCPerformedReason as string,",
				"          DCPerformedRemarks as string,",
				"          IsChargeCalcTriggered as boolean,",
				"          CalcTriggerTime as timestamp,",
				"          ChargeCalcErrorMessage as string,",
				"          IsDocDmsUpdated as string,",
				"          IsDocDmsUpdatedTime as timestamp,",
				"          DocDmsUpdatedMsg as string,",
				"          IsConvertedToLoan as boolean,",
				"          IsCBTriggered as boolean,",
				"          PreviousAppID as long,",
				"          IsSanctionConsent as boolean,",
				"          SanctionAgreedTime as timestamp,",
				"          IsSanLetterAgreed as boolean,",
				"          SanctionLetterDMSID as string,",
				"          IsMobileNumberVerified as boolean,",
				"          IsTermsCondAgreed as boolean,",
				"          SubBranch as string,",
				"          IsEsigned as boolean,",
				"          EsignedTime as timestamp,",
				"          ESignDMSID as long,",
				"          IsENachCompleted as boolean,",
				"          ENachTime as timestamp,",
				"          ESignRemarks as string,",
				"          IsEligibilityWF as boolean,",
				"          LMSAccountID as string,",
				"          OldWF as string,",
				"          PDType as string,",
				"          status_clean as string,",
				"          customer_type_clean as string,",
				"          loan_amount_clean as decimal(19,2)",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> srcapplication",
				"srcapplication select(mapColumn(",
				"          each(match(/* All input columns */ true()),",
				"               /* Input name */ $$ = $$),",
				"          loan_application_number,",
				"          application_id = id,",
				"          loan_amount = loan_amount_clean,",
				"          loan_type,",
				"          loan_purpose,",
				"          product,",
				"          status = status_clean,",
				"          application_creation_date,",
				"          branch_id,",
				"          customer_category,",
				"          customer_type = customer_type_clean",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selfact",
				"selfact derive(application_key = toString(id)) ~> drvfact",
				"drvfact sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> snkfact"
			]
		}
	}
}